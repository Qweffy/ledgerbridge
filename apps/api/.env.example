# --- Database (Postgres / Neon — pooled connection string) ---
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- QuickBooks Online (Intuit Developer → create an app → Development keys) ---
QBO_CLIENT_ID=""
QBO_CLIENT_SECRET=""
QBO_REDIRECT_URI="http://localhost:3001/oauth/callback"   # must match a Redirect URI on the app
QBO_ENVIRONMENT="sandbox"                                  # sandbox | production
QBO_REALM_ID=""                                            # connected sandbox company id (from the OAuth callback)
# The QBO Customer + Item the bridge maps internal invoices onto. The sync worker
# does not start without these (and QBO_REALM_ID). Find ids via the sandbox UI or a query.
QBO_DEFAULT_CUSTOMER=""
QBO_DEFAULT_ITEM=""
# Access/refresh tokens are obtained at runtime via OAuth2 and stored in oauth_tokens.

# --- Internal invoicing system (simulated) → bridge ---
INTERNAL_WEBHOOK_SECRET=""                                 # HMAC key the internal system signs its webhooks with
INTERNAL_WEBHOOK_TARGET="http://localhost:3001/webhooks/internal"  # where it posts change webhooks (the bridge ingest)

# --- Server ---
PORT="3001"
