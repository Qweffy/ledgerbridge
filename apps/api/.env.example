# --- Database (Postgres) ---
# Reuse Neon like Settle, or a local Postgres via docker-compose.test.yml.
DATABASE_URL="postgresql://user:password@host/ledgerbridge?sslmode=require"

# --- QuickBooks Online (Intuit Developer → create an app → Keys & credentials) ---
QBO_CLIENT_ID=""
QBO_CLIENT_SECRET=""
QBO_REDIRECT_URI="http://localhost:3000/oauth/callback"
QBO_ENVIRONMENT="sandbox"            # sandbox | production
QBO_REALM_ID=""                      # sandbox company id — set after the OAuth connect
QBO_WEBHOOK_VERIFIER_TOKEN=""        # Intuit signs change webhooks with this (verify the signature)
# Access/refresh tokens are obtained at runtime via OAuth2 and stored in the DB
# (access token ~1h, refresh token ~100d → refresh before expiry).

# --- Internal invoicing system (the "other side" — you host/simulate a minimal one) ---
INTERNAL_API_URL="http://localhost:4000"
INTERNAL_WEBHOOK_SECRET=""
